{
  "name": "photo-archive",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "sh -c 'trap \"kill 0\" EXIT; (cd backend && bun run dev) & (cd frontend && bun run dev) && wait'",
    "dev:backend": "sh -c 'cd backend && bun run dev'",
    "dev:frontend": "sh -c 'cd frontend && bun run dev'",
    "db:generate": "sh -c 'cd backend && bun run prisma:generate'",
    "db:migrate": "sh -c 'cd backend && bun run prisma:migrate'",
    "db:seed": "sh -c 'cd backend && bun run prisma:seed'"
  },
  "packageManager": "bun@1.2.18"
}
