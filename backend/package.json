{
  "name": "@photo-archive/backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "check": "tsc -p tsconfig.json",
    "test": "bun test",
    "prisma:generate": "bunx --bun prisma generate --config prisma.config.ts",
    "prisma:migrate": "bunx --bun prisma migrate dev --config prisma.config.ts --name init",
    "prisma:seed": "bun run prisma/seed.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@prisma/client": "^6.8.2",
    "argon2": "^0.41.1",
    "dotenv": "^16.5.0",
    "hono": "^4.7.11",
    "jose": "^5.9.6",
    "sanitize-html": "^2.17.0",
    "sharp": "^0.34.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/sanitize-html": "^2.16.1",
    "bun-types": "^1.3.14",
    "prisma": "^6.8.2",
    "typescript": "^5.8.3"
  }
}
