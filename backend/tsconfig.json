{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "baseUrl": ".",
    "types": [
      "bun-types"
    ],
    "paths": {
      "@modules/*": [
        "modules/*"
      ],
      "@src/*": [
        "src/*"
      ]
    }
  },
  "include": [
    "src",
    "modules",
    "tests"
  ]
}
